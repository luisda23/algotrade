   double fib_swingHigh = 0; int fib_swingHighBar = -1;
   for(int fi = 2; fi < 100 && fib_swingHighBar == -1; fi++) {
      if(fibUp[fi] != EMPTY_VALUE && fibUp[fi] > 0) { fib_swingHigh = fibUp[fi]; fib_swingHighBar = fi; }
   }
   double fib_swingLow = 0; int fib_swingLowBar = -1;
   for(int fj = 2; fj < 100 && fib_swingLowBar == -1; fj++) {
      if(fibDn[fj] != EMPTY_VALUE && fibDn[fj] > 0) { fib_swingLow = fibDn[fj]; fib_swingLowBar = fj; }
   }
   bool fib_uptrend = (fib_swingLowBar > fib_swingHighBar);
   double fib_range = fib_swingHigh - fib_swingLow;
   double fib_382 = fib_uptrend ? fib_swingHigh - fib_range * 0.382 : fib_swingLow + fib_range * 0.382;
   double fib_50  = (fib_swingHigh + fib_swingLow) / 2.0;
   double fib_618 = fib_uptrend ? fib_swingHigh - fib_range * 0.618 : fib_swingLow + fib_range * 0.618;
   double fib_tol = fib_range * 0.04;
   bool fib_atKeyLevel = (MathAbs(bidPrice - fib_382) < fib_tol || MathAbs(bidPrice - fib_50) < fib_tol || MathAbs(bidPrice - fib_618) < fib_tol);
   double srUpBuf[], srDnBuf[], srAtrBuf[];
   ArraySetAsSeries(srUpBuf, true); ArraySetAsSeries(srDnBuf, true); ArraySetAsSeries(srAtrBuf, true);
   CopyBuffer(handleSR_Fractals, 0, 0, 200, srUpBuf);
   CopyBuffer(handleSR_Fractals, 1, 0, 200, srDnBuf);
   CopyBuffer(handleSR_ATR, 0, 0, 1, srAtrBuf);
   double srLevels[400]; int srLevelCount = 0;
   for(int sri = 2; sri < 200 && srLevelCount < 400; sri++) {
      if(srUpBuf[sri] != EMPTY_VALUE && srUpBuf[sri] > 0) srLevels[srLevelCount++] = srUpBuf[sri];
      if(srDnBuf[sri] != EMPTY_VALUE && srDnBuf[sri] > 0) srLevels[srLevelCount++] = srDnBuf[sri];
   }
   double srTol = srAtrBuf[0] * 1.5;
   double srSupport = 0;
   double srResistance = 999999;
   for(int srI = 0; srI < srLevelCount; srI++) {
      int srTouches = 0;
      for(int srJ = 0; srJ < srLevelCount; srJ++) if(MathAbs(srLevels[srI] - srLevels[srJ]) < srTol) srTouches++;
      if(srTouches < 3) continue;
      if(srLevels[srI] < bidPrice && srLevels[srI] > srSupport) srSupport = srLevels[srI];
      if(srLevels[srI] > bidPrice && srLevels[srI] < srResistance) srResistance = srLevels[srI];
   }
   double srBounceTol = srAtrBuf[0] * 0.5;
   double sr_prevClose = iClose(InpSymbol, InpTimeframe, 1);

   if((((rsi[1] < 30 && rsi[2] >= 30)) || ((stochMain[1] > stochSignal[1] && stochMain[2] <= stochSignal[2] && stochMain[1] < 50)) || ((srsi_crossUp && srsi_K < 50)) || ((cci[1] < -100 && cci[2] >= -100)) || ((roc > 0 && rocPrev <= 0)) || ((emaFast[1] > emaSlow[1] && emaFast[2] <= emaSlow[2])) || ((smaFast[1] > smaSlow[1] && smaFast[2] <= smaSlow[2])) || ((macdMain[1] > macdSignal[1] && macdMain[2] <= macdSignal[2])) || ((adxPlus[1] > adxMinus[1] && adxPlus[2] <= adxMinus[2] && adxMain[1] > 20)) || ((psarPrevClose > sar[1] && psarPrevPrevClose <= sar[2])) || ((st_dir == 1 && st_prevDir != 1)) || ((bbPrevClose >= bbUpper[0] && bbPrevPrevClose < bbUpper[1])) || ((bidPrice >= donHigh)) || ((volSpike && bidPrice > volHi5)) || (vwap_crossUp) || ((mfi[1] < 20 && mfi[2] >= 20)) || ((fib_range > 0 && fib_uptrend && fib_atKeyLevel)) || ((srSupport > 0 && (bidPrice - srSupport) < srBounceTol && (bidPrice - srSupport) > 0 && bidPrice > sr_prevClose))) && ((rsi[1] < 40) && (stochMain[1] < 40) && (srsi_K < 50) && (cci[1] < 0) && (roc > 0) && (emaFast[1] > emaSlow[1]) && (smaFast[1] > smaSlow[1]) && (macdMain[1] > macdSignal[1]) && ((adxMain[1] > 20 && adxPlus[1] > adxMinus[1])) && (psarPrevClose > sar[1]) && (st_dir == 1) && (bbPrevClose >= bbMiddle[0]) && (atrActive) && (volSpike) && (obv[1] > obvAvg) && (bidPrice > vwap) && (mfi[1] < 50) && ((fib_range > 0 && fib_uptrend)) && ((srSupport > 0 && bidPrice > srSupport)))) buySignal = true;
   if((((rsi[1] > 70 && rsi[2] <= 70)) || ((stochMain[1] < stochSignal[1] && stochMain[2] >= stochSignal[2] && stochMain[1] > 50)) || ((srsi_crossDown && srsi_K > 50)) || ((cci[1] > 100  && cci[2] <= 100)) || ((roc < 0 && rocPrev >= 0)) || ((emaFast[1] < emaSlow[1] && emaFast[2] >= emaSlow[2])) || ((smaFast[1] < smaSlow[1] && smaFast[2] >= smaSlow[2])) || ((macdMain[1] < macdSignal[1] && macdMain[2] >= macdSignal[2])) || ((adxPlus[1] < adxMinus[1] && adxPlus[2] >= adxMinus[2] && adxMain[1] > 20)) || ((psarPrevClose < sar[1] && psarPrevPrevClose >= sar[2])) || ((st_dir == -1 && st_prevDir != -1)) || ((bbPrevClose <= bbLower[0] && bbPrevPrevClose > bbLower[1])) || ((bidPrice <= donLow)) || ((volSpike && bidPrice < volLo5)) || (vwap_crossDown) || ((mfi[1] > 80 && mfi[2] <= 80)) || ((fib_range > 0 && !fib_uptrend && fib_atKeyLevel)) || ((srResistance < 999999 && (srResistance - bidPrice) < srBounceTol && (srResistance - bidPrice) > 0 && bidPrice < sr_prevClose))) && ((rsi[1] > 60) && (stochMain[1] > 60) && (srsi_K > 50) && (cci[1] > 0) && (roc < 0) && (emaFast[1] < emaSlow[1]) && (smaFast[1] < smaSlow[1]) && (macdMain[1] < macdSignal[1]) && ((adxMain[1] > 20 && adxPlus[1] < adxMinus[1])) && (psarPrevClose < sar[1]) && (st_dir == -1) && (bbPrevClose <= bbMiddle[0]) && (atrActive) && (volSpike) && (obv[1] < obvAvg) && (bidPrice < vwap) && (mfi[1] > 50) && ((fib_range > 0 && !fib_uptrend)) && ((srResistance < 999999 && bidPrice < srResistance)))) sellSignal = true;

   Print("[eval] bar=", TimeToString(currentBarTime, TIME_DATE|TIME_MINUTES), " buy=", buySignal, " sell=", sellSignal);

   if(buySignal)
   {
      double ask = SymbolInfoDouble(InpSymbol, SYMBOL_ASK);
      double sl = ask * (1 - InpStopLoss/100.0);
      double tp = ask * (1 + InpTakeProfit/100.0);
      double lot = GetTradeLot(MathAbs(ask - sl) / SymbolInfoDouble(InpSymbol, SYMBOL_POINT));
      if(!trade.Buy(lot, InpSymbol, ask, sl, tp, "TestBot BUY"))
         Print("BUY rechazada: ", trade.ResultRetcode(), " ", trade.ResultRetcodeDescription(), " (lot=", lot, " sl=", sl, " tp=", tp, ")");
      else
         Print("BUY enviada: lot=", lot, " sl=", sl, " tp=", tp);
   }
   else if(sellSignal)
   {
      double bid = SymbolInfoDouble(InpSymbol, SYMBOL_BID);
      double sl = bid * (1 + InpStopLoss/100.0);
      double tp = bid * (1 - InpTakeProfit/100.0);
      double lot = GetTradeLot(MathAbs(sl - bid) / SymbolInfoDouble(InpSymbol, SYMBOL_POINT));
      if(!trade.Sell(lot, InpSymbol, bid, sl, tp, "TestBot SELL"))
         Print("SELL rechazada: ", trade.ResultRetcode(), " ", trade.ResultRetcodeDescription(), " (lot=", lot, " sl=", sl, " tp=", tp, ")");
      else
