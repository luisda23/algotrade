int OnInit()
{
   Print("═══════════════════════════════════════");
   Print("  TestBot");
   Print("  Generado por YudBot · TEST_DATE");
   Print("═══════════════════════════════════════");

   trade.SetExpertMagicNumber(InpMagicNumber);
   trade.SetMarginMode();
   trade.SetTypeFillingBySymbol(InpSymbol);
   trade.SetDeviationInPoints(10);

   if(!symbolInfo.Name(InpSymbol))
   {
      Print("Error: No se puede acceder al símbolo ", InpSymbol);
      return(INIT_FAILED);
   }

   handleRSI = iRSI(InpSymbol, InpTimeframe, 14, PRICE_CLOSE);
   if(handleRSI == INVALID_HANDLE) { Print("Error creando RSI"); return INIT_FAILED; }
   handleStoch = iStochastic(InpSymbol, InpTimeframe, 5, 3, 3, MODE_SMA, STO_LOWHIGH);
   if(handleStoch == INVALID_HANDLE) { Print("Error creando Stochastic"); return INIT_FAILED; }
   handleStochRSI_internalRSI = iRSI(InpSymbol, InpTimeframe, 14, PRICE_CLOSE);
   if(handleStochRSI_internalRSI == INVALID_HANDLE) { Print("Error creando Stoch RSI"); return INIT_FAILED; }
   handleCCI = iCCI(InpSymbol, InpTimeframe, 14, PRICE_TYPICAL);
   if(handleCCI == INVALID_HANDLE) { Print("Error creando CCI"); return INIT_FAILED; }
   handleMomentum = iMomentum(InpSymbol, InpTimeframe, 14, PRICE_CLOSE);
   if(handleMomentum == INVALID_HANDLE) { Print("Error creando ROC"); return INIT_FAILED; }
   handleEMA_fast = iMA(InpSymbol, InpTimeframe, 9, 0, MODE_EMA, PRICE_CLOSE);
   handleEMA_slow = iMA(InpSymbol, InpTimeframe, 21, 0, MODE_EMA, PRICE_CLOSE);
   if(handleEMA_fast == INVALID_HANDLE || handleEMA_slow == INVALID_HANDLE) { Print("Error creando EMA"); return INIT_FAILED; }
   handleSMA_fast = iMA(InpSymbol, InpTimeframe, 9, 0, MODE_SMA, PRICE_CLOSE);
   handleSMA_slow = iMA(InpSymbol, InpTimeframe, 21, 0, MODE_SMA, PRICE_CLOSE);
   if(handleSMA_fast == INVALID_HANDLE || handleSMA_slow == INVALID_HANDLE) { Print("Error creando SMA"); return INIT_FAILED; }
   handleMACD = iMACD(InpSymbol, InpTimeframe, 12, 26, 9, PRICE_CLOSE);
   if(handleMACD == INVALID_HANDLE) { Print("Error creando MACD"); return INIT_FAILED; }
   handleADX = iADX(InpSymbol, InpTimeframe, 14);
   if(handleADX == INVALID_HANDLE) { Print("Error creando ADX"); return INIT_FAILED; }
   handleSAR = iSAR(InpSymbol, InpTimeframe, 0.02, 0.2);
   if(handleSAR == INVALID_HANDLE) { Print("Error creando Parabolic SAR"); return INIT_FAILED; }
   handleST_ATR = iATR(InpSymbol, InpTimeframe, 10);
   if(handleST_ATR == INVALID_HANDLE) { Print("Error creando SuperTrend"); return INIT_FAILED; }
   handleBB = iBands(InpSymbol, InpTimeframe, 20, 0, 2.0, PRICE_CLOSE);
   if(handleBB == INVALID_HANDLE) { Print("Error creando Bollinger"); return INIT_FAILED; }
   handleATR = iATR(InpSymbol, InpTimeframe, 14);
   if(handleATR == INVALID_HANDLE) { Print("Error creando ATR"); return INIT_FAILED; }
   handleOBV = iOBV(InpSymbol, InpTimeframe, VOLUME_TICK);
   if(handleOBV == INVALID_HANDLE) { Print("Error creando OBV"); return INIT_FAILED; }
   handleMFI = iMFI(InpSymbol, InpTimeframe, 14, VOLUME_TICK);
   if(handleMFI == INVALID_HANDLE) { Print("Error creando MFI"); return INIT_FAILED; }
   handleFib_Fractals = iFractals(InpSymbol, InpTimeframe);
   if(handleFib_Fractals == INVALID_HANDLE) { Print("Error creando Fib Fractals"); return INIT_FAILED; }
   handleSR_Fractals = iFractals(InpSymbol, InpTimeframe);
   handleSR_ATR = iATR(InpSymbol, InpTimeframe, 14);
   if(handleSR_Fractals == INVALID_HANDLE || handleSR_ATR == INVALID_HANDLE) { Print("Error creando S/R"); return INIT_FAILED; }


   initialBalance = AccountInfoDouble(ACCOUNT_BALANCE);
   dailyStartBalance = initialBalance;
   lastDayCheck = TimeCurrent();

   Print("Bot inicializado correctamente");
   Print("Balance inicial: ", initialBalance);
   Print("Apalancamiento: 1:", InpLeverage);

   return(INIT_SUCCEEDED);
}

